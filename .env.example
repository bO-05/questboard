# Notion MCP Configuration
# Option A: Self-hosted MCP server 
NOTION_TOKEN=ntn_yo...oken
MCP_SERVER_URL=http://localhost:3100/mcp
MCP_AUTH_TOKEN=***

# Option B: Hosted Notion MCP (requires OAuth - see README)
# MCP_SERVER_URL=https://mcp.notion.com/mcp
# MCP_ACCESS_TOKEN=your_o...oken
# MCP_REFRESH_TOKEN=your_r...oken
# MCP_CLIENT_ID=your_registered_client_id
# MCP_CLIENT_SECRET=
# MCP_TOKEN_EXPIRES_AT=2026-03-26T12:34:56Z
# Tip: run `questboard hosted-login` to populate these automatically.

# LLM Provider Configuration
# Provider: "anthropic" (default) or "openai" (for Mistral, OpenRouter, OpenAI, or any OpenAI-compatible API)
LLM_PROVIDER=openai

# Option A: Anthropic (default)
# LLM_PROVIDER=anthropic
# ANTHROPIC_API_KEY=***
# LLM_MODEL=claude-sonnet-4-20250514

# Option B: Mistral AI (Recommended for QuestBoard - best creative/cost balance)
# LLM_PROVIDER=openai
# OPENAI_API_KEY=***  # Your Mistral API key
# OPENAI_BASE_URL=https://api.mistral.ai/v1
# LLM_MODEL=mistral-medium-2508  # Best balance: creative writing + JSON reliability + cheap input

# Option C: OpenRouter (or any OpenAI-compatible API)
# LLM_PROVIDER=openai
# OPENAI_API_KEY=***
# OPENAI_BASE_URL=https://openrouter.ai/api/v1
# LLM_MODEL=openrouter/auto

# Optional grounding providers for `questboard onboard`
# EXA_API_KEY=***
# PERPLEXITY_API_KEY=***

# QuestBoard Settings
PLAYER_NAME=Hero
DIFFICULTY=normal
